{
  "name": "@shapeshift-labs/frontier-lang-dialects",
  "version": "0.1.1",
  "description": "Runtime-neutral dialect and projection evidence records for Frontier Lang semantic graphs.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "bench",
    "benchmarks/package-bench.mjs"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "npm run build && node test/smoke.mjs",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit -p test/tsconfig.json",
    "bench": "npm run build && node bench/smoke.mjs",
    "prepare": "npm run build",
    "prepack": "npm run lint && npm test",
    "pack:dry": "npm pack --dry-run",
    "lint": "node scripts/strict-source-policy.mjs"
  },
  "keywords": [
    "frontier",
    "frontier-lang",
    "semantic-merge",
    "dialects",
    "compiler"
  ],
  "author": "ShapeShift Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/siliconjungle/-shapeshift-labs-frontier-lang-dialects.git"
  },
  "bugs": {
    "url": "https://github.com/siliconjungle/-shapeshift-labs-frontier-lang-dialects/issues"
  },
  "homepage": "https://github.com/siliconjungle/-shapeshift-labs-frontier-lang-dialects#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@shapeshift-labs/frontier-lang-kernel": "0.3.12"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
